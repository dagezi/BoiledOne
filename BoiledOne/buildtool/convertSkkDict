#!/usr/bin/env swift

import OSLog
import Foundation

let logger: Logger = Logger(subsystem: "BoiledOne", category: "dictionaryConverter")

var entries: [String: Array<String>] = [:]

func load(dictPath: String) {
    do {
        let content: String = try String(contentsOfFile: dictPath, encoding: .japaneseEUC)
        var lineCount: Int = 0
        content.enumerateLines { line, stop in
            lineCount += 1
            if !line.starts(with: ";") {
                parseLine(line, lineNumber: lineCount)
            }
        }
        logger.info("load: \(lineCount) lines and \(entries.count) entries added successfully")
    } catch {
        logger.error("Reading from \(dictPath): \(error)")
    }
}

func parseLine(_ line: String, lineNumber: Int) {    
    guard let m = line.firstMatch(of: #/ +/#) else { 
        logger.info("parseLine: Ignore the line \(lineNumber) as it doesn't have any spaces")
        return 
    }
    let srcEnd = m.range.lowerBound   
    let destStart = m.range.upperBound

    let origSrc = line[..<srcEnd]
    let src = String(origSrc.replacing(#/[A-Za-z]*$/#, with: ""))
    guard src.wholeMatch(of: #/^[\p{Hiragana}ー]+$/#) != nil else { 
        logger.info("parseLine: Ignore not Hiragana key \(origSrc)")
        return 
    }

    let dest = line[destStart...]
    for candidate in dest.split(separator: "/") {
        if (candidate != "") {
            let wordEnd =  candidate.firstIndex(of: ";") ?? candidate.endIndex
            let c = String(candidate[..<wordEnd])
            var candidates = entries[src, default: []]
            if !candidates.contains(c) {
                candidates.append(c)
                entries[src] = candidates
            }
        }
    }
}

func dump() {
    let srcs = entries.keys.sorted()
    for src in srcs {
        for dest in entries[src]! {
            print("\(src) \(dest)")
        }
    }
}

if CommandLine.arguments.count > 1 {
    let skkDict = CommandLine.arguments[1]
    load(dictPath: skkDict)
    dump()
} else {
    print("Usage: convertSkkDict.swift SKK_DICT_FILE")
}
